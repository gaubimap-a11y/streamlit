[databricks]
server_hostname = "dbc-xxxx.cloud.databricks.com"
http_path = "/sql/1.0/warehouses/xxxxxxxxxxxx"
access_token = "dapiXXXXXXXXXXXXXXXX"
catalog = "tmn_kobe"
socket_timeout_seconds = 60
retry_stop_after_attempts_count = 3
retry_stop_after_attempts_duration_seconds = 60
warehouse_id = ""
source_label = "sql_warehouse"
poll_seconds = 1
timeout_seconds = 60
wait_timeout = "10s"

[auth]
enabled_login_modes = ["internal", "sso"]

[google_oauth]
client_id = ""
client_secret = ""
redirect_uri = ""
authorization_endpoint = "https://accounts.google.com/o/oauth2/v2/auth"
token_endpoint = "https://oauth2.googleapis.com/token"
userinfo_endpoint = "https://openidconnect.googleapis.com/v1/userinfo"
scopes = ["openid", "email", "profile"]
hosted_domain = ""
prompt = "select_account"
