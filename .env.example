# Databricks Configuration for Local Development
# Copy this file to .env and fill in your values

# Your Databricks workspace URL (without https://)
# Example: dbc-42ab559d-0aee.cloud.databricks.com
DATABRICKS_HOST=

# Your personal access token or service principal token
# Generate at: Workspace Settings > Developer > Access Tokens
DATABRICKS_TOKEN=

# SQL Warehouse ID to use for queries
# Find at: SQL Warehouses > Click warehouse > Copy HTTP Path or ID
# Example: 0a7d3e487553e579
DATABRICKS_WAREHOUSE_ID=

# Optional tuning values (use defaults if not sure)
DATABRICKS_SQL_POLL_SECONDS=1
DATABRICKS_SQL_TIMEOUT_SECONDS=60
DATABRICKS_SQL_WAIT_TIMEOUT=10s

# Note: When deployed to Databricks Apps, these values are ignored
# and the app automatically uses its service principal credentials
